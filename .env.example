# Đổi tên file này thành .env và điền API keys

# ── Bắt buộc ──────────────────────────────────────────
# Lấy tại: https://console.groq.com → API Keys → Create key
# Free tier: 14,400 req/day | 70B: 6,000 TPM | 8B: 30,000 TPM
GROQ_API_KEY=your_groq_api_key

# ── Tuỳ chọn (fallback khi Groq rate-limit) ──────────
# Lấy tại: https://aistudio.google.com/apikey
# Free tier: 15 RPM | 1,000,000 TPM (Gemini Flash)
GEMINI_API_KEY=your_gemini_api_key
